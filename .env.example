# ============================================
# Aja Agora — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aja_agora

# ---- Anthropic API ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Adapter Configuration ----
# Which administradora data source to use
# Valid values: mock
ADMINISTRADORA_ADAPTER=mock

# ---- Feature Flags ----
# Show landing page at "/". If false, redirects to /admin/login
FEATURE_LANDING_PAGE=true
# Show only kanban pipeline without sidebar navigation
FEATURE_ONLY_KANBAN=false
# Show admin dashboard at "/admin"
FEATURE_DASHBOARD=true
# Show pipeline page at "/admin/pipeline"
FEATURE_PIPELINE=true
# Show attendants page at "/admin/attendants"
FEATURE_ATTENDANTS=true
# Show personas pages under "/admin/personas"
FEATURE_PERSONAS=true

# ---- SendGrid (transactional email) ----
# API key from SendGrid dashboard (Settings → API Keys)
SENDGRID_API_KEY=
# Verified sender email (Single Sender Verification or domain-auth)
SENDGRID_FROM_EMAIL=

# ---- App URL ----
# Public base URL used to build links in outgoing emails (e.g. invite links)
# In dev with Cloudflare tunnel: https://aja-agora.twobrainstechnology.com
APP_URL=http://localhost:3000
