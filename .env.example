# ============================================
# Aja Agora — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
#
# Convenção TwoBrains local-dev por workspace:
#   - WORKSPACE_NAME = nome do diretório do worktree atual
#     (gerado automaticamente pela skill .claude/skills/local-dev)
#   - Letta vem de ~/.tb-local/_shared/ (compartilhado entre projetos)
#   - Postgres é isolado por workspace (container aja-pg-<workspace>)
#
# Ver: ~/.tb-local/CONVENTIONS.md

# ---- Workspace ----
# Cada branch/worktree é um workspace isolado. Portas distintas no host
# pra permitir múltiplas branches rodando em paralelo sem colisão.
# Convenção: incremente DB_HOST_PORT a partir de 5433 e APP_HOST_PORT
# a partir de 3000 por workspace.
WORKSPACE_NAME=develop
DB_HOST_PORT=5434
APP_HOST_PORT=3010

# ---- Database ----
# App rodando no host (npm run dev) → use localhost
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/aja_agora
# App rodando em container (docker compose --profile containerized) → o
# compose já injeta DATABASE_URL apontando pra aja-pg-<workspace>:5432

# ---- Redis (FIX-44: worker de polling do desfecho, BullMQ) ----
# Host → DNS .orb.local do redis do workspace; container → o compose injeta.
REDIS_URL=redis://redis.aja-<workspace>.orb.local:6379
# Dias sem avanço que marcam a proposta como perdida (timeout nosso).
PERDIDO_INACTIVITY_DAYS=14

# ---- Admin seed (src/scripts/seed-admin.ts) ----
# Exigido pelo docker-compose.yml (ADMIN_EMAIL/ADMIN_PASSWORD required).
# Senha só de dev local — mínimo 8 caracteres.
ADMIN_EMAIL=admin@ajaagora.com.br
ADMIN_PASSWORD=admin123

# ---- Anthropic API ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Memória cross-channel (Postgres — FIX-81 / ADR 2026-06-25) ----
# Backend de memória: `postgres` (default, vive na tabela memory_identities do
# DATABASE_URL acima) ou `noop` (desliga a memória). O Letta foi removido.
MEMORY_ADAPTER=postgres
# Separa ambientes (prod/dev/local-<workspace>). Faz parte da chave de identidade.
MEMORY_NAMESPACE=aja-agora-local-develop

# ---- Bevi (fonte ÚNICA de dados — mock em runtime é PROIBIDO) ----
# Descoberta (passos 1-4): Trilho B self-contract. Hash público da loja —
# sem ele a descoberta FALHA ALTO (não existe fallback fictício).
BEVI_SELFCONTRACT_HASH=
# BEVI_SELFCONTRACT_BASE_URL=        # default: core-production-selfcontract (DO)

# Fechamento (passo 5): API de Parceiro. Exige token da loja parceira.
PROPOSAL_GATEWAY=bevi
BEVI_API_TOKEN=
# BEVI_BASE_URL=
# BEVI_PRODUCT_ID=

# ---- Identidade do usuário (gate identify, D1) ----
# Chave de cifra do CPF (AES-256-GCM). Gere com: openssl rand -base64 32
# NUNCA commitar valor real; sem ela o gate identify falha alto.
IDENTITY_ENC_KEY=

# ---- Documentos do cliente (FIX-82 — S3 nosso = fonte da verdade) ----
# Bucket DEDICADO de PII de identidade (RG/CNH/comprovante) — nunca o mesmo do
# S3_BUCKET acima (esse é só de manual de administradora). Em dev usa o MinIO
# local (mesmo S3_ENDPOINT/S3_REGION/credenciais acima, bucket diferente).
S3_CLIENT_DOCS_BUCKET=aja-client-docs
# SSE-KMS: ARN/id da chave dedicada em prod. Bucket+KMS de prod são
# PENDENTE-KAIRO (provisionamento IaC) — em dev/MinIO deixe vazio (MinIO local
# não tem KMS configurado; setar aqui sem KMS de verdade quebra o upload).
S3_CLIENT_DOCS_KMS_KEY_ID=
# Host pelo qual o BROWSER/WhatsApp alcança o storage — a URL de download é
# ASSINADA com ele (SigV4 cobre o Host; trocar depois invalida a assinatura).
# Em dev o app fala com o MinIO por `aja-shared-minio:9000` (rede do Docker),
# host que o browser não resolve. Em prod (S3 real) deixe VAZIO.
S3_PUBLIC_ENDPOINT=


# ---- WhatsApp (Meta Cloud API oficial, Graph v21.0) ----
# Envio via src/lib/whatsapp/api.ts. Sem BSP — bate direto na Graph.
# Token de acesso permanente do app da Meta (System User token).
WHATSAPP_ACCESS_TOKEN=
# ID do número de telefone do WhatsApp Business (envio de mensagens é aqui).
WHATSAPP_PHONE_NUMBER_ID=
# WhatsApp Business Account ID — CRIAR/LISTAR templates é no WABA, não no phone
# number id (POST/GET /{WABA_ID}/message_templates). PENDENTE-KAIRO: obter o
# valor real na Meta Business; sem ele as operações de template falham alto.
WHATSAPP_WABA_ID=
# Token de verificação do webhook (echo do hub.challenge no handshake da Meta).
WHATSAPP_VERIFY_TOKEN=
# App Secret da Meta — valida a assinatura X-Hub-Signature-256 dos webhooks.
WHATSAPP_APP_SECRET=

# ---- SendGrid (transactional email) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ---- App URL ----
APP_URL=http://localhost:3000

# Celular REAL de teste pro simulador WhatsApp. A Bevi valida o celular contra o CPF,
# entao o simulador (waId sintetico SIM-uuid) precisa de um numero real pareado com o CPF
# da conta de teste. PII real fica no .env.local/vault, nunca commitado. Ex.: 5562999999999
SIMULATOR_TEST_CELULAR=
