# ============================================
# Aja Agora — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
#
# Convenção TwoBrains local-dev por workspace:
#   - WORKSPACE_NAME = nome do diretório do worktree atual
#     (gerado automaticamente pela skill .claude/skills/local-dev)
#   - Letta vem de ~/.tb-local/_shared/ (compartilhado entre projetos)
#   - Postgres é isolado por workspace (container aja-pg-<workspace>)
#
# Ver: ~/.tb-local/CONVENTIONS.md

# ---- Workspace ----
# Cada branch/worktree é um workspace isolado. Portas distintas no host
# pra permitir múltiplas branches rodando em paralelo sem colisão.
# Convenção: incremente DB_HOST_PORT a partir de 5433 e APP_HOST_PORT
# a partir de 3000 por workspace.
WORKSPACE_NAME=develop
DB_HOST_PORT=5434
APP_HOST_PORT=3010

# ---- Database ----
# App rodando no host (npm run dev) → use localhost
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/aja_agora
# App rodando em container (docker compose --profile containerized) → o
# compose já injeta DATABASE_URL apontando pra aja-pg-<workspace>:5432

# ---- Redis (FIX-44: worker de polling do desfecho, BullMQ) ----
# Host → DNS .orb.local do redis do workspace; container → o compose injeta.
REDIS_URL=redis://redis.aja-<workspace>.orb.local:6379
# Dias sem avanço que marcam a proposta como perdida (timeout nosso).
PERDIDO_INACTIVITY_DAYS=14

# ---- Anthropic API ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Letta (compartilhado via ~/.tb-local/_shared/) ----
# App no host:
LETTA_BASE_URL=http://localhost:8283
# App em container (dentro de tb-local-net):
# LETTA_BASE_URL=http://letta:8283
LETTA_API_KEY=                                # = LETTA_SERVER_PASS de ~/.tb-local/_shared/.env.shared
LETTA_NAMESPACE=aja-agora-local-develop
LETTA_EMBEDDING=openai/text-embedding-3-small

# ---- Bevi (fonte ÚNICA de dados — mock em runtime é PROIBIDO) ----
# Descoberta (passos 1-4): Trilho B self-contract. Hash público da loja —
# sem ele a descoberta FALHA ALTO (não existe fallback fictício).
BEVI_SELFCONTRACT_HASH=
# BEVI_SELFCONTRACT_BASE_URL=        # default: core-production-selfcontract (DO)

# Fechamento (passo 5): API de Parceiro. Exige token da loja parceira.
PROPOSAL_GATEWAY=bevi
BEVI_API_TOKEN=
# BEVI_BASE_URL=
# BEVI_PRODUCT_ID=

# ---- Identidade do usuário (gate identify, D1) ----
# Chave de cifra do CPF (AES-256-GCM). Gere com: openssl rand -base64 32
# NUNCA commitar valor real; sem ela o gate identify falha alto.
IDENTITY_ENC_KEY=

# ---- SendGrid (transactional email) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ---- App URL ----
APP_URL=http://localhost:3000
