# ============================================
# Aja Agora — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aja_agora

# ---- Anthropic API ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Adapter Configuration ----
# Which administradora data source to use
# Valid values: mock
ADMINISTRADORA_ADAPTER=mock

# ---- Feature Flags ----
# Show landing page at "/". If false, redirects to /admin/login
FEATURE_LANDING_PAGE=true
# Show only kanban pipeline without sidebar navigation
FEATURE_ONLY_KANBAN=false
