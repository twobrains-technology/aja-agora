# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.pnpm-store

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# segredos decriptados do vault (secrets.sh decrypt) — PII/credenciais, NUNCA versionar
contas-teste.env
*.dec.env
*.decrypted.env

# vercel
.vercel

# bundles gerados em build-time (esbuild)
scripts/*.bundle.mjs
scripts/*.bundle.js
scripts/*.bundle.cjs

# typescript
*.tsbuildinfo
next-env.d.ts
*.png
.playwright-mcp/
scripts/eval-calibrate.bundle.cjs

# Playwright artifacts
playwright-report/
test-results/
