		"@hookform/resolvers": "^5.2.2",
		"@sendgrid/mail": "^8.1.6",
		"ai": "^6.0.158",
		"better-auth": "^1.6.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.2",
		"embla-carousel-react": "^8.6.0",
		"lucide-react": "^1.8.0",
		"motion": "^12.38.0",
		"next": "16.2.3",
		"next-themes": "^0.4.6",
		"nuqs": "^2.8.9",
		"pg": "^8.20.0",
		"react": "19.2.4",
		"react-day-picker": "^9.14.0",
		"react-dom": "19.2.4",
		"react-hook-form": "^7.72.1",
		"react-markdown": "^10.1.0",
		"react-use": "^17.6.0",
		"recharts": "^3.8.0",
		"shadcn": "^4.2.0",
		"tailwind-merge": "^3.5.0",
