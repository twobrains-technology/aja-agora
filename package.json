{
	"name": "aja-agora",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"format": "biome check --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:bundle": "esbuild scripts/migrate-guard.mjs --bundle --platform=node --target=node22 --format=cjs --packages=bundle --outfile=scripts/migrate-guard.bundle.cjs",
		"db:migrate:runtime": "node scripts/migrate-guard.bundle.cjs",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"eval:calibrate:bundle": "esbuild scripts/eval-calibrate.ts --bundle --platform=node --target=node22 --format=cjs --packages=bundle --tsconfig=tsconfig.json --outfile=scripts/eval-calibrate.bundle.cjs",
		"eval:calibrate": "npm run eval:calibrate:bundle && node --env-file-if-exists=.env scripts/eval-calibrate.bundle.cjs"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.69",
		"@ai-sdk/react": "^3.0.177",
		"@base-ui/react": "^1.3.0",
